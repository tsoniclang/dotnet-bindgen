{
  "name": "@tsonic/dotnet-bindgen",
  "version": "0.7.55",
  "description": "Generate TypeScript declarations from .NET assemblies",
  "type": "module",
  "bin": {
    "dotnet-bindgen": "bin.js"
  },
  "main": "./index.js",
  "exports": {
    ".": "./index.js",
    "./bin.js": "./bin.js"
  },
  "files": [
    "bin.js",
    "index.js",
    "lib",
    "README.md"
  ],
  "scripts": {
    "build": "dotnet publish src/DotnetBindgen/DotnetBindgen.csproj -c Release -o lib/",
    "prepack": "npm run build",
    "test": "bash test/scripts/run-all.sh",
    "test:generated-types": "node scripts/typecheck-generated-packages.mjs",
    "test:unit": "dotnet test tests/DotnetBindgen.Tests/DotnetBindgen.Tests.csproj -c Release --verbosity quiet"
  },
  "keywords": [
    "tsonic",
    "typescript",
    "dotnet",
    "csharp",
    "codegen",
    "bindings"
  ],
  "author": "Tsonic Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tsoniclang/dotnet-bindgen.git"
  },
  "devDependencies": {
    "@typescript/native-preview": "7.0.0-dev.20260617.2"
  }
}
